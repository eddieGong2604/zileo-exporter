# Zileo (dev proxy + Vercel Edge api/companies.ts — không đưa vào bundle).
ZILEO_API_KEY=

# Apollo: org search, people search, bulk_match enrich (dev proxy; Edge api/apollo-*.ts).
APOLLO_API_KEY=

# Instantly API key (Bearer token) for campaigns and bulk lead add.
INSTANTLY_API_KEY=

# Postgres connection string for /api/enriched-contacts.
POSTGRES_URL=
# Alternative name (also supported): DATABASE_URL=

# Test giống production: npx vercel dev (cần Vercel CLI, link project).
# npm run preview chỉ phục vụ static — /api/companies sẽ 404.
